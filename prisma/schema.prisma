generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String             @id
  title          String
  category       String
  marketplace    String
  salePrice      Decimal            @db.Decimal(10, 2)
  imageUrl       String
  createdAt      DateTime           @default(now())
  supplier       SupplierProduct?
  opportunities  Opportunity[]
  profitAnalyses ProfitAnalysis[]
  riskAssessments RiskAssessment[]
  listingDrafts  ListingDraft[]
  listingMetrics ListingMetric[]
  automationActions AutomationAction[]
  notifications  Notification[]
}

model SupplierProduct {
  id                   String   @id
  productId            String   @unique
  supplierName         String
  supplierUrl          String
  cost                 Decimal  @db.Decimal(10, 2)
  shippingCost         Decimal  @db.Decimal(10, 2)
  shippingDays         Int
  inStock              Boolean
  priceIncreasePercent Decimal  @db.Decimal(5, 2)
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id                   String  @id
  productId            String
  score                Int
  expectedMonthlySales Int
  reason               String
  product              Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProfitAnalysis {
  id              String   @id @default(cuid())
  productId       String
  estimatedProfit Decimal  @db.Decimal(10, 2)
  margin          Decimal  @db.Decimal(5, 2)
  recommendation  String
  createdAt       DateTime @default(now())
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RiskAssessment {
  id        String   @id @default(cuid())
  productId String
  level     String
  flags     String[]
  summary   String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ListingDraft {
  id          String   @id @default(cuid())
  productId   String
  title       String
  description String
  keywords    String[]
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ListingMetric {
  id             String   @id @default(cuid())
  productId      String
  activeDays     Int
  views          Int
  watchers       Int
  salesLast7Days Int
  totalSales     Int
  returnRate     Decimal  @db.Decimal(5, 4)
  recordedAt     DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AutomationAction {
  id        String   @id
  productId String
  type      String
  priority  String
  message   String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id
  productId String
  severity  String
  message   String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
